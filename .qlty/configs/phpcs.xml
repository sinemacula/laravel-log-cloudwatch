<?xml version="1.0"?>
<ruleset name="Project">

    <rule ref="SineMaculaLaravelPackage"/>

    <!-- DisallowMixedTypeHint disabled only on the files that genuinely receive
         arbitrary, framework-shaped data: the factory's Laravel channel
         `array $config`, the framework-untyped `$app` in the base test case, and
         reflected handler properties in the factory test. Everywhere else the
         rule stays on; PHPStan still guards unsafe mixed access. -->
    <rule ref="SlevomatCodingStandard.TypeHints.DisallowMixedTypeHint">
        <exclude-pattern>*/src/CloudWatchLoggerFactory.php</exclude-pattern>
        <exclude-pattern>*/tests/TestCase.php</exclude-pattern>
        <exclude-pattern>*/tests/Unit/CloudWatchLoggerFactoryTest.php</exclude-pattern>
    </rule>

    <file>src</file>
    <file>tests</file>

</ruleset>
